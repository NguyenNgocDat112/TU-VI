rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- GLOBAL HELPERS ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && request.auth.token.email == 'truongduchungsonjr03@gmail.com'; }
    function isOwner(userId) { return (isSignedIn() && request.auth.uid == userId) || isAdmin(); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    // Widened ID validation to allow Unicode (Vietnamese names) and different chart ID formats
    function isValidId(id) { return id is string && id.size() <= 256; }
    
    // Type checking helpers
    function isString(val, max) { return val is string && val.size() <= max; }
    function isNumber(val) { return val is number; }
    function isBool(val) { return val is bool; }

    // --- ENTITY VALIDATIONS ---

    function isValidUser(data) {
      // Allow partial updates for interpretedChartIds or other fields
      return (data.keys().hasAll(['uid', 'email']) || (isSignedIn() && request.method == 'update'))
        && (!data.keys().hasAny(['uid']) || isString(data.uid, 128))
        && (!data.keys().hasAny(['email']) || isString(data.email, 256))
        && (!data.keys().hasAny(['displayName']) || data.displayName == null || isString(data.displayName, 256))
        && (!data.keys().hasAny(['photoURL']) || data.photoURL == null || isString(data.photoURL, 1024))
        && (!data.keys().hasAny(['lastLoginAt']) || data.lastLoginAt is timestamp)
        && (!data.keys().hasAny(['interpretedChartIds']) || (data.interpretedChartIds is list && data.interpretedChartIds.size() <= 200))
        && (!data.keys().hasAny(['rank']) || isString(data.rank, 50))
        && (!data.keys().hasAny(['customQuotaLimit']) || isNumber(data.customQuotaLimit));
    }

    function isValidHistory(data) {
      return (data.keys().hasAll(['name', 'gender', 'solarDateTimestamp']) || (isSignedIn() && request.method == 'update'))
        && (!data.keys().hasAny(['name']) || isString(data.name, 256))
        && (!data.keys().hasAny(['gender']) || isString(data.gender, 20))
        && (!data.keys().hasAny(['solarDateTimestamp']) || isNumber(data.solarDateTimestamp))
        && (!data.keys().hasAny(['hour']) || isNumber(data.hour))
        && (!data.keys().hasAny(['minute']) || isNumber(data.minute))
        && (!data.keys().hasAny(['isLunar']) || isBool(data.isLunar))
        && (!data.keys().hasAny(['isLeap']) || isBool(data.isLeap))
        && (!data.keys().hasAny(['lastViewedAt']) || data.lastViewedAt is timestamp);
    }

    function isValidInterpretation(data) {
      return data.keys().hasAll(['text'])
        && isString(data.text, 200000)
        && (!data.keys().hasAny(['generatedAt']) || data.generatedAt is timestamp);
    }

    // --- MATCH BLOCKS ---

    match /api_key_usage/{keyId} {
      allow read: if isAdmin();
      allow write: if isSignedIn();
    }

    match /admin_alerts/{alertId} {
      allow create: if incoming().keys().hasAll(['type', 'error', 'timestamp', 'resolved'])
                    && isString(incoming().type, 100)
                    && isString(incoming().error, 5000)
                    && (!incoming().keys().hasAny(['keyUsed']) || isString(incoming().keyUsed, 256))
                    && incoming().timestamp is timestamp
                    && isBool(incoming().resolved);
      allow read, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if isAdmin();
      allow delete: if isAdmin();
      allow create: if isOwner(userId) 
                    && incoming().uid == userId
                    && isValidUser(incoming());
      allow update: if isOwner(userId)
                    && isValidUser(incoming())
                    && incoming().uid == existing().uid; // Immutable UID
      
      // History Subcollection
      match /history/{chartId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) 
                             && isValidId(chartId)
                             && isValidHistory(incoming());
        allow delete: if isOwner(userId);

        // Interpretations Subcollection
        match /interpretations/{palaceName} {
          allow read: if isOwner(userId);
          allow create, update: if isOwner(userId)
                               && isValidId(palaceName)
                               && isValidInterpretation(incoming())
                               && exists(/databases/$(database)/documents/users/$(userId)/history/$(chartId));
        }
      }
    }
  }
}
